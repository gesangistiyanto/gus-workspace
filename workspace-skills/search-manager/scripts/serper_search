#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: serper_search \"query\" [gl] [hl]" >&2
  exit 1
fi

Q="$1"
GL_IN="${2:-}"
HL_IN="${3:-}"
CFG_FILE="$HOME/.config/search-manager/config.json"
KEYS_FILE="$HOME/.openclaw/search_keys.json"

cfg_get() {
  python3 - <<'PY' "$CFG_FILE" "$1"
import json,sys
p,key=sys.argv[1],sys.argv[2]
try:
    cfg=json.load(open(p))
except Exception:
    print(''); raise SystemExit(0)
val=cfg.get(key)
if isinstance(val,list): print(','.join(val))
elif val is None: print('')
else: print(val)
PY
}

keys_json_get() {
  python3 - <<'PY' "$KEYS_FILE" "$1"
import json,sys
p,key=sys.argv[1],sys.argv[2]
try:
    d=json.load(open(p))
except Exception:
    print(''); raise SystemExit(0)
v=d.get(key)
if isinstance(v,list): print(','.join([x for x in v if x]))
elif v is None: print('')
else: print(v)
PY
}

DEFAULT_GL="id"
DEFAULT_HL="id"
ORDER="serper,tavily"
if [ -f "$CFG_FILE" ]; then
  cgl="$(cfg_get default_gl || true)"; [ -n "$cgl" ] && DEFAULT_GL="$cgl"
  chl="$(cfg_get default_hl || true)"; [ -n "$chl" ] && DEFAULT_HL="$chl"
  corder="$(cfg_get order || true)"; [ -n "$corder" ] && ORDER="$corder"
fi
GL="${GL_IN:-$DEFAULT_GL}"
HL="${HL_IN:-$DEFAULT_HL}"

SERPER_KEYS="${SERPER_API_KEYS:-}"
if [ -z "$SERPER_KEYS" ] && [ -f "$KEYS_FILE" ]; then
  SERPER_KEYS="$(keys_json_get serper_api_keys || true)"
fi
if [ -z "$SERPER_KEYS" ] && [ -n "${SERPER_API_KEY:-}" ]; then
  SERPER_KEYS="$SERPER_API_KEY"
fi

TAVILY_KEYS="${TAVILY_API_KEYS:-}"
if [ -z "$TAVILY_KEYS" ] && [ -f "$KEYS_FILE" ]; then
  TAVILY_KEYS="$(keys_json_get tavily_api_keys || true)"
fi
if [ -z "$TAVILY_KEYS" ] && [ -n "${TAVILY_API_KEY:-}" ]; then
  TAVILY_KEYS="$TAVILY_API_KEY"
fi

serper_call_with_key() {
  local key="$1"
  curl -sS -X POST 'https://google.serper.dev/search' \
    -H "X-API-KEY: ${key}" \
    -H 'Content-Type: application/json' \
    -d "{\"q\":\"${Q//\"/\\\"}\",\"gl\":\"$GL\",\"hl\":\"$HL\"}"
}

tavily_call() {
  local key="$1"
  curl -sS -X POST 'https://api.tavily.com/search' \
    -H 'Content-Type: application/json' \
    -d "{\"api_key\":\"${key}\",\"query\":\"${Q//\"/\\\"}\",\"search_depth\":\"basic\",\"topic\":\"general\",\"max_results\":10}"
}

try_serper() {
  [ -n "$SERPER_KEYS" ] || return 1
  IFS=',' read -r -a KEYS <<< "$SERPER_KEYS"
  for k in "${KEYS[@]}"; do
    k="$(echo "$k" | xargs)"
    [ -n "$k" ] || continue
    resp="$(serper_call_with_key "$k" || true)"
    if [ -n "$resp" ] && echo "$resp" | grep -q '"organic"'; then
      echo "$resp"; return 0
    fi
  done
  return 1
}

try_tavily() {
  [ -n "$TAVILY_KEYS" ] || return 1
  IFS=',' read -r -a KEYS <<< "$TAVILY_KEYS"
  for k in "${KEYS[@]}"; do
    k="$(echo "$k" | xargs)"
    [ -n "$k" ] || continue
    resp="$(tavily_call "$k" || true)"
    if [ -n "$resp" ] && echo "$resp" | grep -q '"results"'; then
      echo "$resp"; return 0
    fi
  done
  return 1
}

try_engine() {
  local e="$1"
  case "$e" in
    serper) try_serper ;;
    tavily) try_tavily ;;
    *) return 1 ;;
  esac
}

IFS=',' read -r -a ENGINES <<< "$ORDER"
for e in "${ENGINES[@]}"; do
  e="$(echo "$e" | xargs | tr '[:upper:]' '[:lower:]')"
  if out="$(try_engine "$e")"; then
    echo "$out"
    exit 0
  fi
done

echo '{"error":"Search failed: all configured engines unavailable/failed."}'
exit 1
